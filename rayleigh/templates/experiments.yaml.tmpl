# experiments.yaml — the executable experiment spec (MACHINERY, git-ignored).
# Authored during `rayleigh init` (the interactive design/prereg session, following
# designdocs/PLANNING.md). Consumed by `conduct_exp` (runs the cells) and
# `process_outputs` (renders the preregistered outputs + findings).
#
# The atomic unit is the EXPERIMENT: one question + one design + one metric + planned
# outputs = one finding. A "sweep" is just the most common shape of an experiment's
# `design`. Below the experiment, the design expands to CELLS (one param combo x one
# seed) — the parallel work items conduct_exp dispatches to code/.
#
# ── FILE-LEVEL (shared by every experiment) ─────────────────────────────────────────
cycle: "{{CYCLE}}"
project: {{PROJECT}}
brief: >
  (the overarching research question for this cycle — filled from the init brief)

code:
  path: {{CODE_PATH}}
  package: {{PACKAGE}}
  run_adapter:                     # HOW conduct_exp turns ONE cell into ONE run.
                                   # Discovered during init by reading code/.
    kind: import                   # import | subprocess
    # import CONTRACT — one file per cell:      callable(params: dict, seed: int, output: str)
    #                   several files per cell:  callable(params: dict, seed: int, outputs: dict)
    #                                            (outputs = {name: path}; see `outputs:` below)
    #   Runs one cell and writes each artifact. If code/'s real entrypoint has a different
    #   signature, author a thin shim (in code/ or results/) that adapts it, and point
    #   `entrypoint` at the shim.
    entrypoint: "{{PACKAGE}}_adapter:run_one"   # "module:callable"
    # subprocess CONTRACT: rayleigh writes {**params, "seed": seed} to a per-cell JSON config,
    #   then runs `command`, substituting {config}, {seed}, any {param}, {out} (the/first
    #   artifact), and {out_<name>} per named output:
    # command: "python -m {{PACKAGE}}.cli run --config {config} --output {out}"

    # ONE artifact per cell — the common case:
    output_template: "data/{experiment}/{cellkey}_seed{seed}.parquet"  # placeholders: {experiment} {cellkey} {seed} {param}
    # …OR SEVERAL artifacts per cell (e.g. a model that writes a trajectory + a summary file).
    # A cell counts as done only when ALL its outputs exist:
    # outputs:
    #   timeseries: "data/{experiment}/{cellkey}_seed{seed}_timeseries.parquet"
    #   summary:    "data/{experiment}/{cellkey}_seed{seed}_summary.parquet"

    workers: 8                     # default parallelism (per-experiment override allowed)

  # output_adapter:                # OPTIONAL — how process_outputs reads a cell's metrics.
  #   load: "{{PACKAGE}}_adapter:load_metrics"   # callable(outputs: dict[name, path]) -> {metric: value}
  #   Default (no adapter): JSON dict of scalars, or numeric column means of parquet/csv;
  #   with several artifacts, metric keys are prefixed by name (e.g. `summary.rmse`, `timeseries.peak`).

  # analysis_r:                    # OPTIONAL — run YOUR OWN R script instead of the generated one.
  #   "analysis/custom.R"          #   Path (relative to results/). rayleigh still writes the tidy
  #                                #   data to analysis/data/<E>.csv; your script reads it and writes
  #                                #   figures (<E>_*.png/.pdf) + tables/stats (<E>_*.csv) by the same
  #                                #   naming convention so the report can collect them.
  # NOTE: process_outputs does NOT compute analytical products itself — it generates a base-R +
  # ggplot2 script (results/analysis/<E>.R) from the `outputs:` below and runs it. The script + the
  # tidy data are durable: `Rscript results/analysis/<E>.R` regenerates every figure/table/stat any
  # time, independently of rayleigh. (Machines running process_outputs need R + ggplot2 installed.)

# ── PER-EXPERIMENT (a list; add one block per experiment) ────────────────────────────
experiments:
  # ---- EXAMPLE experiment — replace with the real ones during the init session ----
  - id: E1
    title: "(short human label)"
    mode: confirmatory             # confirmatory | exploratory  (drives honest reporting)
    resource: cpu                  # cpu | gpu — which trundlr resource `rayleigh queue` runs this
                                   #   experiment's conduct_exp on (default cpu; set gpu only if this
                                   #   experiment's code path needs one). Ignored by local runs.
    question: "(the specific question this experiment answers)"

    design:
      kind: sweep                  # sweep | conditions | oat | ablation
      axes:                        # each axis is a named list; cells = the cartesian product
        param_a: [lo, hi]
        param_b: [0.0, 0.5, 1.0]
      seeds: 16                    # Monte Carlo replications per cell

    # fixed:                       # OPTIONAL — constant params merged into EVERY cell of this
    #   mode: monkey               #   experiment (not swept). Use for an arm selector or any
    #                              #   parameter pinned across the whole grid; reaches the adapter
    #                              #   in `params`. Becomes part of the cellkey (so two experiments
    #                              #   sharing a grid but differing by a fixed param don't collide).
    #                              #   A swept axis of the same name overrides it.

    workers: 8                     # INTENDED parallel cells for THIS experiment (upper bound).
                                   #   Set <= cores, a power of two (8/16/32…). conduct_exp then
                                   #   pilot-measures the first cell's RAM and LOWERS this if the
                                   #   pool wouldn't fit usable RAM. At RUNTIME a watchdog samples
                                   #   free memory and, if a heavier-than-pilot cell pushes the box
                                   #   toward OOM, kills the biggest worker and retries it with a
                                   #   halved pool (outputs are written atomically, so a killed cell
                                   #   just re-runs — no half-written data). So this is intent, not a
                                   #   safety number — the runtime enforces the fit and the box can't
                                   #   OOM. GPU: size to VRAM (often 1-few).
                                   #   (Disable the guard with `conduct_exp --no-mem-guard`.)
    # seeds: 64                    # optional: override the design's seeds for this experiment
    # budget_hours: 2              # optional: trundlr scheduling window for `rayleigh queue`

    metric:                        # PREREGISTERED — fixed before any data exists
      name: (the measured quantity)
      reduce: "(how cells/seeds collapse to the quantity, e.g. mean over seeds)"

    expected_direction: "(the predicted result and its theoretical basis)"

    outputs:                       # PREREGISTERED — planned here, then GENERATED IN R by
                                   # process_outputs (ggplot2 figures; base-R tables/stats/regressions).
                                   # A list: a finding may be a figure, a table, a regression, a stat…
                                   # (A per-metric summary-statistics table is always produced too.)
      - kind: figure
        type: line                 # line | bar | heatmap | scatter | ...
        x: param_b
        y: (metric)
        facet: param_a
        caption: "(what the reader should take away)"
      # HEATMAP form — x and y are the two swept AXES; the colour is a third field `z`
      # (the metric). z MUST be a metric column, not one of the axes:
      # - kind: figure
      #   type: heatmap
      #   x: param_b               # column axis
      #   y: param_a               # row axis
      #   z: (metric)              # colour = the metric to show over the x*y plane
      #   caption: "..."
      # - kind: table
      #   rows: param_a
      #   cols: param_b
      #   cell: (metric)
      #   caption: "..."
      # REGRESSION — fit in R (lm, or glm when `family:` is set); coefficients + SE/t/p -> a CSV:
      # - kind: regression
      #   name: (short_id)
      #   formula: "(metric) ~ param_a + param_b"   # a base-R model formula, used verbatim
      #   family: binomial         # OPTIONAL — set to use glm(..., family=...) instead of lm()
      #   caption: "..."
      # `stat` / `artifact` kinds rayleigh can't derive from cell data — it names them in the
      # report; produce them in an adapter helper (or your `analysis_r` script) and reference them.
